# ── Application ───────────────────────────────────────────────
NODE_ENV=production
IMAGE_TAG=latest

# ── Docker Hub ────────────────────────────────────────────────
DOCKER_HUB_USERNAME=your_dockerhub_username

# ── MongoDB ───────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change_this_strong_password
MONGO_APP_PASSWORD=change_this_app_password
